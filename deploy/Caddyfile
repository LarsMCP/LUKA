# Caddyfile für LUKA
#
# nip.io kodiert die Server-IP im Hostnamen (kein eigener DNS-Eintrag nötig).
# Caddy erkennt daran einen "echten" Hostnamen und holt automatisch ein
# Let's-Encrypt-Zertifikat (HTTPS). WICHTIG: keinen Port (":80") anhängen,
# sonst deaktiviert Caddy automatisches HTTPS.

luka.167.233.225.216.nip.io {
	reverse_proxy app:8000
}
